{
  "name": "lifeos",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader runner",
    "build": "tsc -b && vite build --configLoader runner",
    "preview": "vite preview --configLoader runner",
    "lint": "eslint .",
    "test": "vitest run --configLoader runner",
    "test:unit": "vitest run --configLoader runner --exclude \"src/**/*.integration.test.ts\"",
    "test:integration": "vitest run --configLoader runner taskOperations.integration.test.ts",
    "test:coverage": "vitest run --configLoader runner --coverage",
    "test:e2e": "npm run build && node e2e/ejecutar-e2e.mjs",
    "test:e2e:report": "playwright show-report",
    "cap:copy": "npx cap copy",
    "cap:sync": "npx cap sync",
    "android:open": "npx cap open android",
    "android:dev": "npm run build && npx cap sync android"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fullcalendar/core": "^6.1.15",
    "@fullcalendar/daygrid": "^6.1.15",
    "@fullcalendar/interaction": "^6.1.15",
    "@fullcalendar/react": "^6.1.15",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^1.1.7",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.469.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.5",
    "vitest": "^4.1.8"
  }
}
